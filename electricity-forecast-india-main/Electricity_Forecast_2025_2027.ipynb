    "axes[1,0].fill_between(yoy.index, yoy.values, alpha=0.15, color='#534AB7')\n",
    "axes[1,0].set_title('Year-over-Year Avg Monthly Bill')\n",
    "axes[1,0].set_ylabel('₹ Bill')\n",
    "for x, y in zip(yoy.index, yoy.values):\n",
